PORT=5000

# Neon PostgreSQL (recommended on VPS — no local Postgres needed)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Local/VPS Postgres (only if DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mothrly
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_SSL=false

ACCESS_TOKEN=your_whatsapp_cloud_api_token
PHONE_NUMBER_ID=your_meta_phone_number_id
ADMIN_WHATSAPP_NUMBER=+91XXXXXXXXXX
